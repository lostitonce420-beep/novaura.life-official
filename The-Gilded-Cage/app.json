{
  "expo": {
    "name": "The Gilded Cage",
    "slug": "gilded-cage",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gildedcage",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gildedcage.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2C2416",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.gildedcage.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2C2416",
          "dark": {
            "backgroundColor": "#2C2416"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to upload custom character portraits."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
